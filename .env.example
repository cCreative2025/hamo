# Supabase — use the new publishable/secret key format (legacy anon/service_role
# are being phased out and have been disabled on this project).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Safe to ship to the browser — corresponds to the "Publishable key" in
# Supabase Dashboard → Settings → API Keys.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Server-only. Never commit or expose. Corresponds to the "Secret key".
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# App Configuration
NEXT_PUBLIC_APP_NAME=Hamo
NEXT_PUBLIC_APP_URL=http://localhost:3000
